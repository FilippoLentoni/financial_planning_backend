    "deploy:prod": "cdk deploy FinancialPlanningBackend-ProdStack"
  },
  "dependencies": {
    "@aws-cdk/aws-bedrock-agentcore-alpha": "^2.252.0-alpha.0",
    "@aws-cdk/aws-bedrock-alpha": "^2.252.0-alpha.0",
    "aws-cdk-lib": "^2.252.0",
    "constructs": "^10.4.2"
  },
  "devDependencies": {
    "@types/node": "^24.10.1",
    "aws-cdk": "^2.252.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3"
  }
}
