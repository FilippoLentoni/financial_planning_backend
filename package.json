{
  "name": "financial-planning-backend",
  "version": "1.0.0",
  "private": true,
  "bin": {
    "financial-planning-backend": "bin/app.js"
  },
  "scripts": {
    "build": "tsc",
    "watch": "tsc -w",
    "test": "npm run build && python3 evaluator/test_eval_config.py",
